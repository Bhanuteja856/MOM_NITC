<!-- Invite Batchmates Modal -->
<div id="inviteModal" class="modal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6);">
    <div class="modal-content" style="background-color: white; margin: 15% auto; padding: 25px; border-radius: 8px; width: 90%; max-width: 400px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); text-align: center;">
        <span class="close" id="closeInviteModal" style="color: #888; float: right; font-size: 28px; font-weight: bold; cursor: pointer; transition: color 0.3s;" onmouseover="this.style.color='#d9534f'" onmouseout="this.style.color='#888'">&times;</span>
        <h3 style="margin-top: 0; color: #0D8ABC;">Invite Batchmates</h3>
        <p style="color: #555; margin-bottom: 20px;">Choose how you want to invite your batchmates:</p>
        <div style="display: flex; flex-direction: column; gap: 15px;">
            <button id="inviteMailBtn" class="btn" style="background-color: #0D8ABC; color: white; border: none; padding: 12px 20px; border-radius: 5px; cursor: pointer; font-size: 1em; font-weight: bold; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">✉️ Invite through Mail</button>
            <button id="inviteLinkBtn" class="btn" style="background-color: #28a745; color: white; border: none; padding: 12px 20px; border-radius: 5px; cursor: pointer; font-size: 1em; font-weight: bold; transition: opacity 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">🔗 Invite through Link</button>
        </div>
    </div>
</div>